{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lotus Teaching Invoices",
  "version": "0.1.0",
  "identifier": "com.houmus.teaching-invoices",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Lotus Teaching Invoices",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxMzEzNDFBOEQwRkQ5RjkKUldUNTJRK05HalF4MGZpWlRzNTZBYnI3cVREODdzbHFLemExM0pWV2EvaUo4SHRkcGV5Tk5acU0K",
      "endpoints": [
        "https://github.com/damageboy/lotus-teaching-invoices/releases/latest/download/latest.json"
      ]
    }
  }
}
