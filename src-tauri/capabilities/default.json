{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    { "identifier": "http:default", "allow": [{ "url": "https://calendar.google.com/**" }] },
    "fs:default",
    "fs:allow-app-write",
    "fs:write-all",
    "dialog:default",
    "shell:allow-open"
  ]
}
