{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://calendar.google.com/**" },
        { "url": "https://oauth2.googleapis.com/**" },
        { "url": "https://gmail.googleapis.com/**" }
      ]
    },
    "fs:default",
    "fs:allow-app-write",
    "fs:write-all",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:create-app-specific-dirs",
    { "identifier": "fs:scope", "allow": [{ "path": "$HOME/**" }, { "path": "/tmp/**" }] },
    "dialog:default",
    "shell:allow-open",
    "log:default"
  ]
}
