{
  "name": "lotus-teaching-invoices",
  "version": "1.0.0",
  "description": "CLI tool to generate yoga teaching invoices from Google Calendar",
  "type": "module",
  "main": "dist/cli/main.js",
  "bin": {
    "lotus-invoices": "dist/cli/main.js"
  },
  "scripts": {
    "dev": "tauri dev",
    "dev:vite": "vite",
    "build": "tauri build",
    "build:vite": "vite build",
    "cli": "tsx src/cli/main.ts",
    "cli:build": "tsc --project tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "bun run build:vite && cargo build --manifest-path src-tauri/Cargo.toml --release && wdio run wdio.conf.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.2",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "commander": "^12.1.0",
    "ical.js": "^2.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "yaml": "^2.6.0",
    "zod": "^3.22.4"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,css,md}": "prettier --write"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@wdio/cli": "^9.24.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0",
    "webdriverio": "^9.24.0"
  }
}
