{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/cli", "src/lib"],
  "exclude": [
    "node_modules",
    "dist",
    "tests",
    "src-tauri",
    "src/lib/pdf",
    "src/lib/gmail",
    "src/lib/config/defaults.ts",
    "src/lib/version.ts"
  ]
}
